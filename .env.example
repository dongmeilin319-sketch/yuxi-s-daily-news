# ===== AI News Project =====
# 复制为 .env.local 后填写真实值

# OpenClaw / LLM（与 ANTHROPIC_API_KEY 二选一或同时配置均可，run_once 会优先读 ANTHROPIC_API_KEY）
ANTHROPIC_API_KEY=
CLAUDE_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# 内容发布
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_BRANCH=main

# Vercel
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=

# 调度配置
CRON_SCHEDULE_DAILY=0 8 * * *
TIMEZONE=Asia/Shanghai

# 发布策略阈值
CONFIDENCE_AUTO_PUBLISH=0.85
CONFIDENCE_NEED_REVIEW=0.70

# 通知（按需）
FEISHU_WEBHOOK_URL=
WECHAT_WEBHOOK_URL=

# Cron 安全（设置后 GET/POST /api/cron/daily 必须带 Authorization: Bearer <CRON_SECRET>）
CRON_SECRET=

# 站点 canonical URL（必填于生产：含 https，无末尾斜杠）
# 例：https://news.example.com
# Vercel 上不填时会临时使用 https://<VERCEL_URL>，绑定自定义域名后请务必改为正式域名并 Redeploy
NEXT_PUBLIC_SITE_URL=

# 归档阈值（天）
ARCHIVE_DAYS=30

# 订阅 Webhook（可选，POST JSON：{ email, source, at }）
SUBSCRIBE_WEBHOOK_URL=

# 每日新闻评分（Neon / Vercel Postgres 连接串；@vercel/postgres 默认读 POSTGRES_URL）
POSTGRES_URL=

# 站点登录（与 APP_USERS_JSON 二选一：未配 JSON 时用单管理员账号）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# 多用户 JSON（可选）：[{"id":"u1","username":"a","password":"..."}]
APP_USERS_JSON=
